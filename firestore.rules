rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Throttling helper
    function isNotThrottled() {
      // Temporarily open to debug permission issues
      return true;
    }
  
    // Lists
    match /lists/{listId} {
      allow read: if request.auth != null && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.sharedUsers
      );
      allow create: if request.auth != null && isNotThrottled();
      allow update, delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.sharedUsers ||
        (request.resource != null && request.auth.uid in request.resource.data.sharedUsers)
      );
      
      // Items inside lists
      match /items/{itemId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && isNotThrottled();
        allow update, delete: if request.auth != null;
      }
    }
    
    // Shares
    match /shares/{shareId} {
      allow read: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow create: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
      allow update, delete: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    
    // Collections
    match /followed_collections/{colId} {
      allow read, write: if request.auth != null;
    }
    

    // User Profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && (
        (request.auth.uid == userId && 
         isNotThrottled() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['fl', 'fuelLevel', 'fuelBatches', 'coinBalance', 'coinBatches', 'isAdmin', 'isMerchant'])) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
      allow create: if request.auth != null && request.auth.uid == userId &&
                    (request.resource.data.fl == 0 || request.resource.data.coinBalance == 0);
                    
      match /following/{storeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Allow followers to update, but not if they are the store owner
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'followersCount', 'averageRating', 'ratingCount', 'updatedAt']) && 
         request.auth.uid != resource.data.ownerId) ||
        // Allow store owner to update their own store (except followers)
        (resource.data.ownerId == request.auth.uid && 
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['followers', 'followersCount', 'averageRating', 'ratingCount'])) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
      allow delete: if request.auth != null && (
        resource.data.ownerId == request.auth.uid || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }
    
    // Store Products
    match /store_products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && (
        (request.resource != null && get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId == request.auth.uid) ||
        (resource != null && get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // Coupons
    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        (request.resource.data.isConsumed == true && resource.data.isConsumed == false && isNotThrottled())
      );
    }
    // Loyalty Cards
    match /loyalty_cards/{cardId} {
      allow read, delete, update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }

    // Images
    match /images/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    // Store Ratings
    match /stores/{storeId}/ratings/{userId} {
      allow read: if true;
      allow write: if false; // Must use rateStoreSecure Cloud Function
    }

    // Orders
    match /orders/{orderId} {
      allow create: if request.auth != null && 
                    request.resource.data.customerId == request.auth.uid &&
                    request.auth.uid != get(/databases/$(database)/documents/stores/$(request.resource.data.storeId)).data.ownerId;
      allow read: if request.auth != null && (
        resource.data.customerId == request.auth.uid || 
        (get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.coinBalance >= 50)
      );
      allow update: if request.auth != null && (
        // Store owner can update status only if balance >= 50 (but should use Cloud Function for status changes)
        // We allow direct updates to chat and deliveryTime, but status is better handled via backend.
        // However, we must allow the Cloud Function to update it.
        // For simplicity, we restrict status updates by store owners here to force CF usage.
        
        // Customer can cancel if pending
        (resource.data.customerId == request.auth.uid && request.resource.data.status == 'cancelled' && resource.data.status == 'pending') ||
        
        // Both parties can add messages to chat or update non-sensitive fields
        ((resource.data.customerId == request.auth.uid || get(/databases/$(database)/documents/stores/$(resource.data.storeId)).data.ownerId == request.auth.uid) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['chat', 'updatedAt', 'deliveryTime']))
      );
    }
  }
}
